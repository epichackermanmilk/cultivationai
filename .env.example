# Copy to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# Internal VPS FastAPI base URL (no trailing slash)
VPS_API_URL=http://localhost:8000

# Secret key shared between Next.js and FastAPI for internal API calls
# Generate with: openssl rand -hex 32
VPS_API_KEY=replace-with-your-own-secret-key

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-replace-with-real-key

# Supabase project URL — https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (keep secret — full DB access)
SUPABASE_SERVICE_KEY=sb_secret_replace-with-real-key
